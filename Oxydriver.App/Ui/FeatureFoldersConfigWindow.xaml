<Window x:Class="Oxydriver.Ui.FeatureFoldersConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurer dossiers fonctionnalité"
        Width="440"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock x:Name="TitleText"
               Grid.Row="0"
               FontWeight="SemiBold"
               TextWrapping="Wrap"
               Margin="0,0,0,10"/>

    <Border Grid.Row="1" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Items}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,0,0,8"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="Annuler" Width="92" Margin="0,0,8,0" Click="CancelClicked"/>
      <Button Content="Enregistrer" Width="92" Click="SaveClicked"/>
    </StackPanel>
  </Grid>
</Window>
