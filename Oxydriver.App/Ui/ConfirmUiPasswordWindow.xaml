<Window x:Class="Oxydriver.Ui.ConfirmUiPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmation de securite"
        Width="420"
        Height="190"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Saisis le mot de passe OXYDRIVER pour autoriser l'import du backup."
               TextWrapping="Wrap"
               Margin="0,0,0,12"/>

    <PasswordBox x:Name="PasswordInput" Grid.Row="1" Margin="0,0,0,10" PasswordChanged="PasswordChanged"/>

    <DockPanel Grid.Row="2" LastChildFill="False">
      <TextBlock x:Name="ErrorText"
                 Foreground="#B91C1C"
                 Visibility="Collapsed"
                 VerticalAlignment="Center"
                 DockPanel.Dock="Left"
                 Text="Mot de passe requis."/>
      <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
        <Button Content="Annuler" Width="90" Margin="0,0,8,0" Click="CancelClicked"/>
        <Button x:Name="ValidateButton" Content="Valider" Width="90" IsEnabled="False" Click="ValidateClicked"/>
      </StackPanel>
    </DockPanel>
  </Grid>
</Window>
