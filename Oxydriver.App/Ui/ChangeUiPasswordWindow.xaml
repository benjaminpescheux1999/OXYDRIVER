<Window x:Class="Oxydriver.Ui.ChangeUiPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Changer le mot de passe"
        Width="430"
        Height="260"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Pour des raisons de securite, vous devez changer votre mot de passe avant de continuer."
               TextWrapping="Wrap"
               Margin="0,0,0,12"/>

    <TextBlock Grid.Row="1" Text="Nouveau mot de passe" Margin="0,0,0,4"/>
    <PasswordBox x:Name="NewPasswordInput" Grid.Row="2" Margin="0,0,0,10" PasswordChanged="PasswordChanged"/>

    <TextBlock Grid.Row="3" Text="Confirmer le mot de passe" Margin="0,0,0,4"/>
    <PasswordBox x:Name="ConfirmPasswordInput" Grid.Row="4" Margin="0,0,0,12" PasswordChanged="PasswordChanged"/>

    <DockPanel Grid.Row="5" LastChildFill="False" VerticalAlignment="Bottom">
      <TextBlock x:Name="ErrorText"
                 Foreground="#B91C1C"
                 Visibility="Collapsed"
                 VerticalAlignment="Center"
                 DockPanel.Dock="Left"
                 TextWrapping="Wrap"/>
      <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
        <Button Content="Annuler" Width="90" Margin="0,0,8,0" Click="CancelClicked"/>
        <Button x:Name="ValidateButton" Content="Valider" Width="90" IsEnabled="False" Click="ValidateClicked"/>
      </StackPanel>
    </DockPanel>
  </Grid>
</Window>
