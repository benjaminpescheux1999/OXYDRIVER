<Window x:Class="Oxydriver.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:accueil="clr-namespace:Oxydriver.Ui.Tabs.Accueil"
        xmlns:parametrage="clr-namespace:Oxydriver.Ui.Tabs.Parametrage"
        xmlns:logs="clr-namespace:Oxydriver.Ui.Tabs.Logs"
        xmlns:autorisations="clr-namespace:Oxydriver.Ui.Tabs.Autorisations"
        Title="OXYDRIVER"
        Icon="pack://application:,,,/Assets/OXYDRIVER.ico"
        Width="980"
        Height="640"
        WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Background="#0F172A" Padding="18">
      <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="OXYDRIVER" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding VersionText}" Foreground="#B3FFFFFF" Margin="12,4,0,0"/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Content="{Binding UpdateActionButtonText}"
                  Command="{Binding CheckUpdatesCommand}"
                  Margin="0,0,12,0"
                  Padding="12,4"/>
          <ProgressBar Width="90"
                       Height="6"
                       Margin="0,0,12,0"
                       IsIndeterminate="True"
                       Visibility="{Binding UpdateLoaderVisibility}"/>
          <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                   Fill="{Binding HeaderIndicatorBrush}"
                   Opacity="{Binding HeaderIndicatorOpacity}"/>
          <TextBlock Foreground="White" FontWeight="SemiBold" Text="{Binding HeaderIndicatorText}" />
        </StackPanel>
      </DockPanel>
    </Border>

    <TabControl Grid.Row="1" Margin="12">
      <TabItem Header="Accueil">
        <accueil:AccueilTabView/>
      </TabItem>
      <TabItem Header="Paramétrage">
        <parametrage:ParametrageTabView/>
      </TabItem>
      <TabItem Header="Logs">
        <logs:LogsTabView/>
      </TabItem>
      <TabItem Header="Autorisations">
        <autorisations:AutorisationsTabView/>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
