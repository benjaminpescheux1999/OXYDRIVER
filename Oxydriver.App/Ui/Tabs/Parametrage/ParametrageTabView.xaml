<UserControl x:Class="Oxydriver.Ui.Tabs.Parametrage.ParametrageTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
  <ScrollViewer>
    <StackPanel Margin="18" Orientation="Vertical" HorizontalAlignment="Stretch">
      <DockPanel Margin="0,0,0,10">
        <Button DockPanel.Dock="Right"
                x:Name="SaveButton"
                Content="Enregistrer"
                Click="SaveFormClicked"
                Padding="12,4"/>
        <Button DockPanel.Dock="Right"
                Content="Annuler"
                Click="CancelFormClicked"
                Margin="0,0,10,0"
                Padding="12,4">
          <Button.Style>
            <Style TargetType="Button">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=Root, Path=HasDraftChanges}" Value="True">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
        </Button>
        <TextBlock DockPanel.Dock="Right"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"
                   Foreground="#065F46"
                   FontWeight="SemiBold"
                   Text="{Binding SaveSettingsFeedbackText}"/>
        <TextBlock Text="Paramètres" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
      </DockPanel>

      <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,12">
        <TextBlock TextWrapping="Wrap" Foreground="#1E3A8A"
                   Text="Les champs ci-dessous sont un formulaire (brouillon). Les changements sont appliqués uniquement au clic sur Enregistrer."/>
      </Border>

      <GroupBox x:Name="ApiGroupBox" Header="Identité &amp; API" Margin="0,0,0,12">
        <Grid Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="URL API"/>
          <TextBox x:Name="ApiBaseUrlTextBox" Grid.Row="0" Grid.Column="1" Text="{Binding ElementName=Root, Path=DraftSettings.ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" TextChanged="DraftValueChanged"/>

          <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Clé d'accès"/>
          <PasswordBox x:Name="AccessKeyPasswordBox" Grid.Row="1" Grid.Column="1" PasswordChanged="AccessKeyChanged"/>

          <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Ancien mot de passe interface"/>
          <PasswordBox x:Name="OldUiPasswordBox" Grid.Row="2" Grid.Column="1" PasswordChanged="OldUiPasswordChanged"/>

          <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Nouveau mot de passe interface"/>
          <PasswordBox x:Name="UiPasswordBox" Grid.Row="3" Grid.Column="1" PasswordChanged="UiPasswordChanged"/>

          <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Version utilitaire"/>
          <TextBlock Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Text="{Binding ElementName=Root, Path=DraftSettings.AppVersion}"/>

          <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Top" Margin="0,6,0,0" Text="Dossiers client"/>
          <Border Grid.Row="5" Grid.Column="1" Margin="0,6,0,0" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="10">
            <StackPanel>
              <ItemsControl ItemsSource="{Binding SelectedFolders}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,8" Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="8,6">
                      <TextBlock Text="{Binding Name}" Foreground="#6B7280"/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Foreground="#6B7280" TextWrapping="Wrap"
                         Text="Dossiers synchronisés automatiquement depuis la clé API (lecture seule)."/>
            </StackPanel>
          </Border>
        </Grid>
      </GroupBox>

      <GroupBox x:Name="SqlGroupBox" Header="SQL Server" Margin="0,0,0,12">
        <Grid Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Nom du serveur"/>
          <TextBox x:Name="SqlServerHostTextBox" Grid.Row="0" Grid.Column="1" Text="{Binding ElementName=Root, Path=DraftSettings.SqlServerHost, UpdateSourceTrigger=PropertyChanged}" TextChanged="DraftValueChanged" />

          <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Authentification"/>
          <ComboBox x:Name="SqlAuthComboBox" Grid.Row="1" Grid.Column="1"
                    ItemsSource="{Binding SqlAuthenticationModes}"
                    SelectedItem="{Binding ElementName=Root, Path=DraftSettings.SqlAuthenticationMode, UpdateSourceTrigger=PropertyChanged}"
                    SelectionChanged="DraftSelectionChanged" />

          <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Nom d'utilisateur admin"/>
          <TextBox x:Name="SqlUserTextBox" Grid.Row="2" Grid.Column="1" Text="{Binding ElementName=Root, Path=DraftSettings.SqlUserName, UpdateSourceTrigger=PropertyChanged}" TextChanged="DraftValueChanged" />

          <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Mot de passe admin"/>
          <PasswordBox x:Name="SqlPasswordBox" Grid.Row="3" Grid.Column="1" PasswordChanged="SqlPasswordChanged"/>

          <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Base par défaut"/>
          <TextBox x:Name="DefaultDatabaseTextBox" Grid.Row="4" Grid.Column="1" Text="{Binding ElementName=Root, Path=DraftSettings.DefaultDatabase, UpdateSourceTrigger=PropertyChanged}" TextChanged="DraftValueChanged" />

          <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Chiffrement"/>
          <ComboBox x:Name="SqlEncryptComboBox" Grid.Row="5" Grid.Column="1"
                    ItemsSource="{Binding SqlEncryptModes}"
                    SelectedItem="{Binding ElementName=Root, Path=DraftSettings.SqlEncryptMode, UpdateSourceTrigger=PropertyChanged}"
                    SelectionChanged="DraftSelectionChanged" />

          <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Certificat serveur"/>
          <CheckBox x:Name="SqlTrustCheckBox" Grid.Row="6" Grid.Column="1"
                    Content="Faire confiance au certificat serveur"
                    IsChecked="{Binding ElementName=Root, Path=DraftSettings.SqlTrustServerCertificate}"
                    Checked="DraftCheckedChanged"
                    Unchecked="DraftCheckedChanged" />

          <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Timeout connexion (s)"/>
          <TextBox x:Name="SqlTimeoutTextBox" Grid.Row="7" Grid.Column="1" Text="{Binding ElementName=Root, Path=DraftSettings.SqlConnectTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" TextChanged="DraftValueChanged" />

          <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Text="Utilisateur OXYDRIVER"/>
          <TextBox Grid.Row="8" Grid.Column="1"
                   IsReadOnly="True"
                   Background="#F3F4F6"
                   Foreground="#374151"
                   Text="{Binding ElementName=Root, Path=DraftSettings.SqlRuntimeUserName, UpdateSourceTrigger=PropertyChanged}" />

          <TextBlock Grid.Row="10" Grid.Column="1"
                     Margin="0,8,0,0"
                     TextWrapping="Wrap"
                     Foreground="#1F2937"
                     Text="{Binding SqlTestStatus}" />
          <TextBlock Grid.Row="11" Grid.Column="1"
                     Margin="0,4,0,0"
                     TextWrapping="Wrap"
                     Foreground="#1F2937"
                     Text="{Binding SqlSecurityStatus}" />
        </Grid>
      </GroupBox>

      <GroupBox x:Name="TunnelGroupBox" Header="Tunnel &amp; exposition" Margin="0,0,0,12">
        <Grid Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Port local"/>
          <TextBox x:Name="LocalPortTextBox" Grid.Row="0" Grid.Column="1" Text="{Binding ElementName=Root, Path=DraftSettings.LocalPort, UpdateSourceTrigger=PropertyChanged}" TextChanged="DraftValueChanged" />

          <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Mode exposition"/>
          <ComboBox x:Name="ExposureModeComboBox" Grid.Row="1" Grid.Column="1"
                    ItemsSource="{Binding ExposureModes}"
                    SelectedItem="{Binding ElementName=Root, Path=DraftSettings.ExposureMode, UpdateSourceTrigger=PropertyChanged}"
                    SelectionChanged="DraftSelectionChanged" />

          <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="URL tunnel manuel"/>
          <TextBox x:Name="ManualTunnelUrlTextBox" Grid.Row="2" Grid.Column="1" Text="{Binding ElementName=Root, Path=DraftSettings.ManualTunnelUrl, UpdateSourceTrigger=PropertyChanged}" TextChanged="DraftValueChanged" />

          <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Provider exposition"/>
          <TextBox x:Name="ExposureProviderTextBox" Grid.Row="3" Grid.Column="1" Text="{Binding ElementName=Root, Path=DraftSettings.ExposureProvider, UpdateSourceTrigger=PropertyChanged}" TextChanged="DraftValueChanged" />

          <TextBlock Grid.Row="4"
                     Grid.Column="1"
                     Margin="0,6,0,0"
                     TextWrapping="Wrap"
                     Foreground="#92400E"
                     Text="Mode manuel : l'URL doit être joignable depuis l'API. Si l'API est publique, une IP VPN privée seule (ex. WireGuard) peut ne pas suffire.">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding ElementName=Root, Path=DraftSettings.ExposureMode}" Value="ManualUrl">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

          <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="URL tunnel publique"/>
          <TextBox Grid.Row="6" Grid.Column="1"
                   IsReadOnly="True"
                   Text="{Binding ElementName=Root, Path=DraftSettings.TunnelPublicUrl, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>
      </GroupBox>

      <GroupBox x:Name="StartupGroupBox" Header="Démarrage &amp; mise à jour">
        <Grid Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Orientation="Horizontal">
            <CheckBox x:Name="LaunchAtStartupCheckBox" Content="Lancer au démarrage Windows" IsChecked="{Binding ElementName=Root, Path=DraftSettings.LaunchAtStartup}" Checked="DraftCheckedChanged" Unchecked="DraftCheckedChanged" />
          </StackPanel>
          <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="{Binding UpdateActionButtonText}" Command="{Binding CheckUpdatesCommand}" />
            <ProgressBar Width="90"
                         Height="6"
                         Margin="10,0,0,0"
                         VerticalAlignment="Center"
                         IsIndeterminate="True"
                         Visibility="{Binding UpdateLoaderVisibility}"/>
            <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" Text="{Binding UpdateStatus}" />
          </StackPanel>
        </Grid>
      </GroupBox>

      <GroupBox x:Name="SftpDebugGroup" Header="SFTP (debug update)" Margin="0,12,0,0">
        <Grid Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Hôte"/>
          <TextBox x:Name="SftpHostTextBox" Grid.Row="0" Grid.Column="1" Text="{Binding ElementName=Root, Path=DraftSettings.SftpHost, UpdateSourceTrigger=PropertyChanged}" TextChanged="DraftValueChanged" />

          <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Port"/>
          <TextBox x:Name="SftpPortTextBox" Grid.Row="1" Grid.Column="1" Text="{Binding ElementName=Root, Path=DraftSettings.SftpPort, UpdateSourceTrigger=PropertyChanged}" TextChanged="DraftValueChanged" />

          <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Utilisateur"/>
          <TextBox x:Name="SftpUsernameTextBox" Grid.Row="2" Grid.Column="1" Text="{Binding ElementName=Root, Path=DraftSettings.SftpUsername, UpdateSourceTrigger=PropertyChanged}" TextChanged="DraftValueChanged" />

          <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Mot de passe"/>
          <PasswordBox x:Name="SftpPasswordBox" Grid.Row="3" Grid.Column="1" PasswordChanged="SftpPasswordChanged"/>

          <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Chemin distant"/>
          <TextBox x:Name="SftpRemotePathTextBox" Grid.Row="4" Grid.Column="1" Text="{Binding ElementName=Root, Path=DraftSettings.SftpRemotePath, UpdateSourceTrigger=PropertyChanged}" TextChanged="DraftValueChanged" />

          <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Tester connexion SFTP" Command="{Binding TestSftpCommand}" />
            <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" Text="{Binding SftpStatus}" />
          </StackPanel>
        </Grid>
      </GroupBox>

      <GroupBox Header="Backup paramétrage" Margin="0,12,0,0">
        <Grid Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="1"
                     Text="Le backup est sécurisé automatiquement avec l'identité OXYDRIVER courante."
                     TextWrapping="Wrap"
                     Foreground="#1F2937"/>

          <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Exporter backup" Click="ExportBackupClicked" Margin="0,0,10,0"/>
            <Button Content="Importer backup" Click="ImportBackupClicked"/>
          </StackPanel>

          <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Statut"/>
          <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0"
                     Text="{Binding BackupStatus}" TextWrapping="Wrap"/>
        </Grid>
      </GroupBox>
    </StackPanel>
  </ScrollViewer>
</UserControl>
