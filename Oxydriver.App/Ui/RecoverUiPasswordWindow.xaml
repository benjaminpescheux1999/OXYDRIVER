<Window x:Class="Oxydriver.Ui.RecoverUiPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recuperation mot de passe API"
        Width="460"
        Height="260"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Saisis les informations API pour recuperer un mot de passe temporaire."
               Margin="0,0,0,10"
               TextWrapping="Wrap"/>

    <TextBlock Grid.Row="1" Text="URL API" Margin="0,0,0,4"/>
    <TextBox x:Name="ApiBaseUrlTextBox" Grid.Row="2" Margin="0,0,0,10" TextChanged="ValueChanged"/>

    <TextBlock Grid.Row="3" Text="Cle d'acces (token OXYDRIVER)" Margin="0,0,0,4"/>
    <TextBox x:Name="AccessKeyTextBox" Grid.Row="4" Margin="0,0,0,12" TextChanged="ValueChanged"/>

    <DockPanel Grid.Row="5" LastChildFill="False">
      <TextBlock x:Name="ErrorText"
                 Foreground="#B91C1C"
                 Visibility="Collapsed"
                 VerticalAlignment="Center"
                 DockPanel.Dock="Left"
                 TextWrapping="Wrap"/>
      <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
        <Button Content="Annuler" Width="90" Margin="0,0,8,0" Click="CancelClicked"/>
        <Button x:Name="ValidateButton" Content="Valider" Width="90" IsEnabled="False" Click="ValidateClicked"/>
      </StackPanel>
    </DockPanel>
  </Grid>
</Window>
